TELEGRAM_BOT_TOKEN=your_token_here

# Telegram chat or group ID to send reminders to
CHAT_ID=-1001234567890

# Postgres connection string (use Neon's pooler endpoint)
DATABASE_URL=postgres://user:password@host/dbname

# Secret Telegram must send with every webhook call (X-Telegram-Bot-Api-Secret-Token)
WEBHOOK_SECRET=your_webhook_secret

# Bearer token Vercel Cron must send to trigger the weekly reminder
CRON_SECRET=your_cron_secret
TELEGRAM_BOT_TOKEN=your_token_here

# Comma-separated room names in rotation order
ROOMS=Zimmer 1,Zimmer 2,Zimmer 6,Zimmer 8

# Telegram chat or group ID to send reminders to
CHAT_ID=-1001234567890

# Optional: how many weeks to generate (default: 8, options: 4, 8, 12)
# SCHEDULE_WEEKS=8

# Optional: path to schedule file (default: schedule.json)
# SCHEDULE_PATH=schedule.json

# Optional: timezone (default: Europe/Berlin)
# TZ=Europe/Berlin

# Optional: send reminder immediately and exit (for testing)
# SEND_NOW=1